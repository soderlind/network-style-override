{
	"name": "soderlind/multisite-override-style",
	"description": "Network-wide CSS and theme.json overrides for WordPress Multisite",
	"type": "wordpress-plugin",
	"license": "GPL-2.0-or-later",
	"autoload": {
		"psr-4": {
			"MultisiteOverrideStyle\\": "src/"
		}
	},
	"autoload-dev": {
		"psr-4": {
			"MultisiteOverrideStyle\\Tests\\": "tests/"
		}
	},
	"require": {
		"php": ">=8.3",
		"soderlind/wordpress-github-updater": "^2.0"
	},
	"require-dev": {
		"phpunit/phpunit": "^11.0",
		"brain/monkey": "^2.6",
		"mockery/mockery": "^1.6"
	},
	"config": {
		"allow-plugins": {
			"composer/installers": true
		},
		"optimize-autoloader": true
	},
	"scripts": {
		"test": "phpunit --testdox",
		"test:coverage": "phpunit --coverage-text",
		"test:acceptance": "bash tests/Acceptance/run-acceptance-tests.sh"
	}
}
